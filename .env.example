# ─── StainSense — Environment Variables ──────────────────────────────────────
# Salin file ini menjadi .env dan isi dengan API key Anda:
#   cp .env.example .env
#
# PENTING: Jangan pernah commit file .env ke Git!
# Pastikan .env sudah ada di .gitignore


# ── Google Gemini API Key ─────────────────────────────────────────────────────
# Dapatkan di: https://aistudio.google.com/app/apikey
# 1. Login dengan akun Google
# 2. Klik "Create API Key"
# 3. Salin dan tempel di sini
GEMINI_API_KEY="put API key here"


# ── OpenRouter API Key ────────────────────────────────────────────────────────
# Dapatkan di: https://openrouter.ai/keys
# 1. Daftar/login di openrouter.ai
# 2. Buka menu "Keys" → "Create Key"
# 3. Salin dan tempel di sini
OPENROUTER_API_KEY="put API key here"


# ── Streamlit Config (opsional) ───────────────────────────────────────────────
# Ubah port default Streamlit jika 8501 sudah terpakai
# STREAMLIT_SERVER_PORT=8501
